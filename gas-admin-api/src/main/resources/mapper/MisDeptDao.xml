<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.gas.api.db.dao.MisDeptDao">
<select id="searchAll" resultType="HashMap">
SELECT id,
name
FROM MIS_DEPT
</select>

<select id="searchDeptByPage" resultType="HashMap">
SELECT id,
name
FROM MIS_DEPT
WHERE 1=1
<if test="name != null and name != ''">
AND name LIKE CONCAT('%', #{name}, '%')
</if>
ORDER BY id ASC
LIMIT #{page}, #{length}
</select>

<select id="searchDeptCount" resultType="int">
SELECT COUNT(*)
FROM MIS_DEPT
WHERE 1=1
<if test="name != null and name != ''">
AND name LIKE CONCAT('%', #{name}, '%')
</if>
</select>

<select id="searchDeptById" resultType="com.example.gas.api.db.pojo.MisDeptEntity">
SELECT id,
name
FROM MIS_DEPT
WHERE id = #{id}
</select>

<insert id="insertDept" parameterType="com.example.gas.api.db.pojo.MisDeptEntity">
INSERT INTO MIS_DEPT (id, name)
VALUES (#{id}, #{name})
</insert>

<update id="updateDept" parameterType="com.example.gas.api.db.pojo.MisDeptEntity">
UPDATE MIS_DEPT
SET
name = #{name}
WHERE id = #{id}
</update>

<delete id="deleteDept">
DELETE FROM MIS_DEPT WHERE id = #{id}
</delete>

<delete id="batchDeleteDept">
DELETE FROM MIS_DEPT WHERE id IN
<foreach collection="list" item="id" open="(" separator="," close=")">
#{id}
</foreach>
</delete>

<select id="getMaxId" resultType="Integer">
SELECT MAX(id) FROM MIS_DEPT
</select>

<select id="checkDeptName" resultType="Integer">
SELECT COUNT(*) FROM MIS_DEPT WHERE name = #{name}
<if test="excludeId != null">
AND id != #{excludeId}
</if>
</select>
</mapper>