<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.gas.api.db.dao.MedicalDeptSubDao">
<select id="searchByDeptId" resultType="HashMap">
SELECT id,
name,
dept_id AS deptId,
location
FROM MEDICAL_DEPT_SUB
WHERE dept_id = #{deptId}
</select>
</mapper>
