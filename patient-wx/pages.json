			}, {
				"path": "video_diagnose/video_diagnose",
				"style": {
					"navigationBarTitleText": "视频问诊",
					"enablePullDownRefresh": false,
					"usingComponents": {
						"trtc-room": "/wxcomponents/trtc-room/trtc-room"
					}
				}
			}, {
				"path": "order_list/order_list",
				"style": {
